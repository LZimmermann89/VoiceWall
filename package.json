{
  "name": "voicewall",
  "version": "0.1.0",
  "private": true,
  "description": "VoiceWall: 100 Prozent lokales, DSGVO-konformes Sprachdiktiergeraet fuer Mac und Windows.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Lars Zimmermann",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=26 <27"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit --composite false -p tsconfig.main.json && tsc --noEmit --composite false -p tsconfig.renderer.json && tsc --noEmit --composite false -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "audit": "npm audit --audit-level=high",
    "sbom": "npm sbom --sbom-format cyclonedx --sbom-type application > sbom.cdx.json",
    "package": "node scripts/generate-icon.mjs && electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@fugood/whisper.node": "1.0.22",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "pdf-parse": "2.4.5",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  }
}
